{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Breadbox",
  "theme": "mint",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#C8482E",
    "light": "#E26B4B",
    "dark": "#A63A24"
  },
  "background": {
    "color": {
      "light": "#FCF9F3",
      "dark": "#1A1612"
    }
  },
  "banner": {
    "content": "🚧 Breadbox is available Early Access. Some features described here may still be in-progress or innaccurate.",
    "dismissible": true
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/canalesb93/breadbox"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "pages": [
          "quick-start",
          {
            "group": "Overview",
            "pages": [
              "introduction",
              "installation",
              "quickstart"
            ]
          },
          {
            "group": "Bank Connections",
            "pages": [
              "connections/overview",
              {
                "group": "Providers",
                "expanded": true,
                "pages": [
                  "connections/teller",
                  "connections/plaid",
                  "connections/csv-import"
                ]
              }
            ]
          },
          {
            "group": "Transactions",
            "pages": [
              "transactions/overview",
              "transactions/categories",
              "transactions/tags",
              "transactions/rules",
              "transactions/review-workflow"
            ]
          },
          {
            "group": "AI Integration",
            "pages": [
              "mcp/overview",
              "mcp/setup",
              "mcp/tools"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "configuration/environment",
              "configuration/api-keys",
              "configuration/backup"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api/overview",
              "api/authentication",
              "api/pagination"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api/accounts",
              "api/transactions",
              "api/categories",
              "api/rules",
              "api/connections",
              "api/users",
              "api/reports"
            ]
          }
        ]
      },
      {
        "tab": "Guides",
        "pages": [
          "automating-breadbox"
        ]
      }
    ]
  },
  "redirects": [
    {
      "source": "/transactions/review-queue",
      "destination": "/transactions/review-workflow"
    }
  ],
  "search": {
    "prompt": "Search..."
  },
  "errors": {
    "404": {
      "redirect": true
    }
  }
}
