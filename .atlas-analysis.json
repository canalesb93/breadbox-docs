  "keyFeatures": [
    "Bank sync via Plaid, Teller, and CSV import",
    "MCP server for AI agent integration (Claude, any MCP-compatible agent)",
    "REST API with cursor pagination, field selection, and filtering",
    "Admin dashboard for connection management and transaction review",
    "Transaction rules engine with recursive AND/OR/NOT conditions for auto-categorization",
    "Review queue for triaging new and uncategorized transactions",
    "Multi-user household support with per-member account assignment",
    "API key authentication with full-access and read-only scopes",
    "AES-256-GCM encryption for all provider credentials at rest",
    "Single binary deployment — one Go binary serves API, MCP, dashboard, and webhooks"
  ],
